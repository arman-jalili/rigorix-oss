# ============================================================
# Rigorix .gitignore — comprehensive
# ============================================================

# --- Build output ---
target/
dist/
build/
out/
bin/
*.class
*.jar
*.war
*.o
*.so
*.dylib
*.exe
*.dll
*.lib
*.a

# --- Dependencies ---
node_modules/
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# --- Graphify knowledge graph output ---
graphify-out/
.graphify_*
!graphify-out/.gitkeep

# --- Environment & secrets ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.yaml
*.secret

# --- Logs ---
*.log
logs/

# --- IDE / editors ---
.idea/
.vscode/
.settings/
*.iml
*.iws
*.ipr
.project
.classpath
*.swp
*.swo
*~
.nyc_output/
.netlify/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Test & Coverage ---
coverage/
.nyc_output/
jacoco.exec
*.lcov
*.cov

# --- Temporary ---
*.tmp
*.temp
*.bak
.cache/
.pytest_cache/
.guardian/

# --- Rust ---
# target/ covered above

# --- Agent / AI ---
# CLAUDE.md and AGENTS.md are project config — keep tracked
# .claude/ is per-developer cache — ignore
.claude/

# --- GitNexus index (rebuildable) ---
.gitnexus/

# --- Python ---
*.egg-info/
*.egg
dist/
build/
pip-wheel-metadata/

# --- Node / JS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
.docker/

# --- Terraform ---
*.tfstate
*.tfstate.*
.terraform/

# --- Specific project ignores ---
guardian-sessions.json
.rigorix/
